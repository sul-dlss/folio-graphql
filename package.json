{
  "name": "sul-folio-graphql-server",
  "version": "1.0.0",
  "description": "",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "npm run update-graphql-schema && npm run codegen && npm run compile",
    "compile": "tsc -p tsconfig-build.json && cp src/schema.graphql dist/schema.graphql",
    "start": "npm run codegen && node --loader ts-node/esm src/server.ts",
    "start:dev": "nodemon",
    "codegen": "graphql-codegen-esm --config codegen.yml",
    "lint": "eslint src -c eslint.config.mjs",
    "test": "jest",
    "sync-folio-schemas": "node scripts/sync-folio-schemas.js",
    "update-graphql-schema": "node scripts/generate-graphql-from-json-schemas.js json-schemas/"
  },
  "jest": {
    "preset": "ts-jest",
    "resolver": "ts-jest-resolver",
    "setupFilesAfterEnv": [
      "<rootDir>/__tests__/setupJest.ts"
    ],
    "testPathIgnorePatterns": [
      "<rootDir>/__tests__/setupJest.ts"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@apollo/datasource-rest": "^6.0.0",
    "@apollo/server": "^5.0.0",
    "@as-integrations/express5": "^1.1.2",
    "@honeybadger-io/js": "^6.4.0",
    "body-parser": "^2.0.0",
    "config": "^4.1.0",
    "cors": "^2.8.5",
    "express": "^5.0.0",
    "graphql": "^16.11.0",
    "graphql-scalars": "^1.18.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.1.0",
    "@graphql-codegen/typescript": "^5.0.0",
    "@graphql-codegen/typescript-resolvers": "^5.1.0",
    "@lifeomic/json-schema-to-graphql-types": "^1.4.2",
    "@types/config": "^3.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.1",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^9.1.0",
    "glob": "^13.0.0",
    "jest": "^30.0.0",
    "jest-fetch-mock": "^3.0.3",
    "nodemon": "^3.0.0",
    "simple-git": "^3.30.0",
    "ts-jest": "^29.1.0",
    "ts-jest-resolver": "^2.0.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.4"
  },
  "overrides": {
    "graphql": "$graphql"
  }
}
